

# settare il background a un colore scuro, es: 0x00E6D8FF
# fare una finestra con dimensioni piu grandi, come  1600 900

A 0.7 255,255,255

# Camera inclinata e laterale, vista diagonale verso il centro
C 7.0,10.0,50.0 0,0,-1 90

# Luce nel centro (Sole)
#L 0.0,0.0,0.0 0.8 255,240,200
L 2.0,8.0,3.0 1 255,240,200


# ----------------
# Sole
sp 0.0,0.0,0.0 8.0 255,200,0

