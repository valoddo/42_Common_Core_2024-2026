   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   fun:_nl_load_locale_from_archive
   fun:_nl_find_locale
   fun:setlocale
}

{
   cat_bindtextdomain
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   fun:set_binding_values*
   fun:bindtextdomain
}

{
   cat_nl_intern_locale_data
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   fun:_nl_intern_locale_data
   fun:_nl_load_locale_from_archive
}

{
   cat_setlocale_strdup
